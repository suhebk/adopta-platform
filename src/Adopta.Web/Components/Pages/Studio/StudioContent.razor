@page "/studio/content"
@rendermode InteractiveServer
@using Adopta.Application.Runtime
@using Adopta.Web.Studio
@inject IStudioContentClient StudioContentClient

<PageTitle>Authored Content</PageTitle>

<section class="studio-content" aria-labelledby="studio-content-title">
    <header class="studio-content__header">
        <div>
            <p class="studio-content__eyebrow">@StudioNavigation.FoundationShellStatus</p>
            <h1 id="studio-content-title">Authored Content</h1>
            <p class="studio-content__intro">
                Authored runtime guidance inventory with a metadata-only draft editor.
                This view uses local foundation data until authenticated tenant-aware
                API integration is approved.
            </p>
        </div>
        <div class="studio-content__notice" role="note">
            @Model.SafeMessage
        </div>
    </header>

    @switch (Model.State)
    {
        case StudioContentPageState.Loading:
            <section class="studio-content__state" aria-live="polite">
                <h2>Loading content</h2>
                <p>Authored content metadata is loading.</p>
            </section>
            break;
        case StudioContentPageState.Empty:
            <section class="studio-content__state">
                <h2>No content yet</h2>
                <p>No authored content metadata is available for this Studio view.</p>
            </section>
            break;
        case StudioContentPageState.Error:
            <section class="studio-content__state studio-content__state--error" role="alert">
                <h2>Content unavailable</h2>
                <p>Authored content could not be loaded. Try again later.</p>
            </section>
            break;
        case StudioContentPageState.NotAuthorized:
            <section class="studio-content__state studio-content__state--warning" role="alert">
                <h2>Not authorized</h2>
                <p>You do not have permission to view authored content.</p>
            </section>
            break;
        case StudioContentPageState.Loaded:
            <section class="studio-content__summary" aria-label="Content lifecycle summary">
                @foreach (var state in LifecycleStates)
                {
                    <article class="studio-content__summary-item">
                        <span class="@GetStatusClass(state)">@FormatLifecycle(state)</span>
                        <strong>@Model.CountByState(state)</strong>
                    </article>
                }
            </section>

            <div class="studio-content__workspace">
                <section class="studio-content__list" aria-labelledby="content-list-title">
                    <div class="studio-content__section-heading">
                        <h2 id="content-list-title">Content inventory</h2>
                        <p>@Model.Items.Count authored items</p>
                    </div>

                    <div class="studio-content__table-wrap">
                        <table class="studio-content__table">
                            <caption>Authored content metadata</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Title</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Lifecycle</th>
                                    <th scope="col">Version</th>
                                    <th scope="col">History</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="@(item.Id == SelectedContent?.Id ? "is-selected" : null)">
                                        <th scope="row">
                                            <a href="@($"#content-{item.Id}")" aria-label="@($"View {item.Title} details")">
                                                @item.Title
                                            </a>
                                            <span>@item.ContentKey</span>
                                        </th>
                                        <td>@FormatContentType(item.ContentType)</td>
                                        <td><span class="@GetStatusClass(item.LifecycleState)">@FormatLifecycle(item.LifecycleState)</span></td>
                                        <td>@(item.CurrentVersion?.Version ?? "Unavailable")</td>
                                        <td>@item.History.LatestSafeActivity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                @if (SelectedContent is not null)
                {
                    <aside class="studio-content__detail" id="@($"content-{SelectedContent.Id}")" aria-labelledby="content-detail-title">
                        <div class="studio-content__section-heading">
                            <h2 id="content-detail-title">@SelectedContent.Title</h2>
                            <span class="@GetStatusClass(SelectedContent.LifecycleState)">
                                @FormatLifecycle(SelectedContent.LifecycleState)
                            </span>
                        </div>

                        <dl class="studio-content__metadata">
                            <div>
                                <dt>Content key</dt>
                                <dd>@SelectedContent.ContentKey</dd>
                            </div>
                            <div>
                                <dt>Application ID</dt>
                                <dd>@SelectedContent.ApplicationId</dd>
                            </div>
                            <div>
                                <dt>Content ID</dt>
                                <dd>@SelectedContent.Id</dd>
                            </div>
                        </dl>

                        <section aria-labelledby="version-metadata-title">
                            <h3 id="version-metadata-title">Version metadata</h3>
                            <div class="studio-content__version-list">
                                @foreach (var version in SelectedContent.Versions)
                                {
                                    <article class="studio-content__version">
                                        <strong>@version.Version</strong>
                                        <span class="@GetStatusClass(version.LifecycleState)">
                                            @FormatLifecycle(version.LifecycleState)
                                        </span>
                                        <time datetime="@version.CreatedAtUtc.ToString("O")">
                                            @version.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm 'UTC'")
                                        </time>
                                    </article>
                                }
                            </div>
                        </section>

                        <section aria-labelledby="history-summary-title">
                            <h3 id="history-summary-title">Audit and history summary</h3>
                            <dl class="studio-content__metadata">
                                <div>
                                    <dt>Latest activity</dt>
                                    <dd>@SelectedContent.History.LatestSafeActivity</dd>
                                </div>
                                <div>
                                    <dt>Lifecycle events</dt>
                                    <dd>@SelectedContent.History.LifecycleEventCount</dd>
                                </div>
                                <div>
                                    <dt>Publishing events</dt>
                                    <dd>@SelectedContent.History.PublishingEventCount</dd>
                                </div>
                                <div>
                                    <dt>Last updated</dt>
                                    <dd>
                                        @if (SelectedContent.History.LatestActivityAtUtc is { } latest)
                                        {
                                            <time datetime="@latest.ToString("O")">@latest.ToString("yyyy-MM-dd HH:mm 'UTC'")</time>
                                        }
                                        else
                                        {
                                            <span>Unavailable</span>
                                        }
                                    </dd>
                                </div>
                            </dl>
                        </section>

                        <section class="studio-content__workflow" aria-labelledby="review-workflow-title">
                            <div class="studio-content__section-heading">
                                <h3 id="review-workflow-title">Review workflow</h3>
                                <span class="studio-content__workflow-state">@FormatWorkflowState(Workflow.State)</span>
                            </div>
                            <p class="studio-content__workflow-help">
                                Local foundation workflow for review decisions only. Publishing remains out of scope.
                            </p>

                            @if (Workflow.HasValidationIssues)
                            {
                                <section class="studio-content__validation" role="alert" aria-labelledby="workflow-validation-title">
                                    <h4 id="workflow-validation-title">Workflow validation summary</h4>
                                    <ul>
                                        @foreach (var issue in Workflow.Issues)
                                        {
                                            <li>@issue.Message</li>
                                        }
                                    </ul>
                                </section>
                            }

                            <dl class="studio-content__metadata studio-content__metadata--readonly">
                                <div>
                                    <dt>Current state</dt>
                                    <dd><span class="@GetStatusClass(Workflow.LifecycleState)">@FormatLifecycle(Workflow.LifecycleState)</span></dd>
                                </div>
                                <div>
                                    <dt>Available transition</dt>
                                    <dd>@FormatWorkflowReadiness(Workflow.LifecycleState)</dd>
                                </div>
                            </dl>

                            <div class="studio-content__workflow-actions" aria-label="Review workflow actions">
                                @if (IsWorkflowActionAvailable(StudioWorkflowActionKind.RequestReview))
                                {
                                    <button type="button" @onclick="() => RunWorkflowActionAsync(StudioWorkflowActionKind.RequestReview)" disabled="@IsWorkflowProcessing" aria-label="Request review for selected draft">
                                        Request review
                                    </button>
                                }
                                @if (IsWorkflowActionAvailable(StudioWorkflowActionKind.Approve))
                                {
                                    <button type="button" @onclick="() => RunWorkflowActionAsync(StudioWorkflowActionKind.Approve)" disabled="@IsWorkflowProcessing" aria-label="Approve selected content">
                                        Approve
                                    </button>
                                }
                                @if (IsWorkflowActionAvailable(StudioWorkflowActionKind.Reject))
                                {
                                    <button type="button" class="studio-content__secondary-button" @onclick="() => RunWorkflowActionAsync(StudioWorkflowActionKind.Reject)" disabled="@IsWorkflowProcessing" aria-label="Return selected content to draft">
                                        Return to draft
                                    </button>
                                }
                                @if (StudioWorkflowActionModel.GetAvailableActions(Workflow.LifecycleState).Count == 0)
                                {
                                    <span>No review workflow actions are available.</span>
                                }
                            </div>

                            <p class="studio-content__workflow-status" role="status" aria-live="polite">
                                @Workflow.SafeMessage
                            </p>
                        </section>
                    </aside>
                }

                <section class="studio-content__editor" aria-labelledby="guidance-editor-title">
                    <div class="studio-content__section-heading">
                        <h2 id="guidance-editor-title">Guidance metadata editor</h2>
                        <span class="studio-content__editor-state">@FormatEditorState(Editor.State)</span>
                    </div>
                    <p class="studio-content__editor-help">
                        Foundation editor for draft metadata only. Content body, review, approval, and publishing actions are out of scope.
                    </p>

                    <form class="studio-content__editor-form" aria-describedby="guidance-editor-help" @onsubmit="SaveDraftAsync" @onsubmit:preventDefault="true" novalidate>
                        <p id="guidance-editor-help" class="studio-content__field-help">
                            Save stores draft metadata through the local Studio content client seam only.
                        </p>

                        @if (Editor.HasValidationIssues)
                        {
                            <section class="studio-content__validation" role="alert" aria-labelledby="guidance-validation-title">
                                <h3 id="guidance-validation-title">Validation summary</h3>
                                <ul>
                                    @foreach (var issue in Editor.Issues)
                                    {
                                        <li>@issue.Message</li>
                                    }
                                </ul>
                            </section>
                        }

                        <div class="studio-content__field">
                            <label for="guidance-title">Title</label>
                            <input id="guidance-title" name="title" type="text" @bind="Editor.Title" aria-required="true" aria-invalid='@HasIssue("title")' />
                        </div>

                        <div class="studio-content__field">
                            <label for="guidance-content-key">Content key</label>
                            <input id="guidance-content-key" name="content-key" type="text" @bind="Editor.ContentKey" aria-required="true" aria-invalid='@HasIssue("contentKey")' />
                            <span class="studio-content__field-help">Use lowercase structural keys such as welcome.tooltip or release-checklist.</span>
                        </div>

                        <div class="studio-content__field">
                            <label for="guidance-content-type">Content type</label>
                            <select id="guidance-content-type" name="content-type" @bind="Editor.ContentType" aria-required="true" aria-invalid='@HasIssue("contentType")'>
                                <option value="">Select content type</option>
                                @foreach (var contentType in ContentTypes)
                                {
                                    <option value="@contentType">@FormatContentType(contentType)</option>
                                }
                            </select>
                        </div>

                        <div class="studio-content__field">
                            <label for="guidance-application">Application</label>
                            <select id="guidance-application" name="application-id" @bind="Editor.ApplicationId" aria-required="true" aria-invalid='@HasIssue("applicationId")'>
                                @foreach (var applicationId in ApplicationIds)
                                {
                                    <option value="@applicationId">@applicationId</option>
                                }
                            </select>
                            <span class="studio-content__field-help">Local application selector placeholder.</span>
                        </div>

                        <dl class="studio-content__metadata studio-content__metadata--readonly">
                            <div>
                                <dt>Lifecycle state</dt>
                                <dd><span class="@GetStatusClass(Editor.LifecycleState)">@FormatLifecycle(Editor.LifecycleState)</span></dd>
                            </div>
                            <div>
                                <dt>Version</dt>
                                <dd>@Editor.Version</dd>
                            </div>
                        </dl>

                        <div class="studio-content__editor-actions">
                            <button type="submit" disabled="@IsSaveDisabled">Save draft</button>
                            <span role="status" aria-live="polite">@Editor.SafeMessage</span>
                        </div>
                    </form>
                </section>
            </div>
            break;
    }
</section>

@code {
    private static readonly StudioContentLifecycleState[] LifecycleStates =
    [
        StudioContentLifecycleState.Draft,
        StudioContentLifecycleState.InReview,
        StudioContentLifecycleState.Approved,
        StudioContentLifecycleState.Published,
        StudioContentLifecycleState.Archived
    ];

    private static readonly RuntimeContentType[] ContentTypes =
    [
        RuntimeContentType.Tooltip,
        RuntimeContentType.Callout,
        RuntimeContentType.Checklist,
        RuntimeContentType.Walkthrough
    ];

    private StudioContentPageModel Model = StudioContentFoundationData.Loading();

    private StudioContentEditorModel Editor = StudioContentEditorModel.Loading();

    private StudioWorkflowActionModel Workflow = StudioWorkflowActionModel.Loading();

    private StudioContentListItem? SelectedContent => Model.SelectedContent;

    private IReadOnlyCollection<Guid> ApplicationIds =>
        Model.Items
            .Select(item => item.ApplicationId)
            .Distinct()
            .OrderBy(applicationId => applicationId)
            .ToArray();

    private bool IsSaveDisabled =>
        Editor.State is StudioContentEditorState.Loading or StudioContentEditorState.Saving ||
        Editor.LifecycleState != StudioContentLifecycleState.Draft;

    private bool IsWorkflowProcessing =>
        Workflow.State == StudioWorkflowActionState.Processing;

    protected override async Task OnInitializedAsync()
    {
        var result = await StudioContentClient.ListAsync(
            new StudioContentListRequest(),
            CancellationToken.None);

        Model = ToPageModel(result);
        Editor = StudioContentEditorModel.FromContent(Model.SelectedContent);
        Workflow = StudioWorkflowActionModel.FromContent(Model.SelectedContent);
    }

    private static string FormatLifecycle(StudioContentLifecycleState state) =>
        state switch
        {
            StudioContentLifecycleState.InReview => "In review",
            _ => state.ToString()
        };

    private static string FormatContentType(RuntimeContentType contentType) =>
        contentType switch
        {
            RuntimeContentType.Tooltip => "Tooltip",
            RuntimeContentType.Callout => "Callout",
            RuntimeContentType.Checklist => "Checklist",
            RuntimeContentType.Walkthrough => "Walkthrough",
            _ => "Unsupported"
        };

    private static string FormatEditorState(StudioContentEditorState state) =>
        state switch
        {
            StudioContentEditorState.Loading => "Loading",
            StudioContentEditorState.Editing => "Editing draft",
            StudioContentEditorState.Saving => "Saving",
            StudioContentEditorState.Saved => "Saved",
            StudioContentEditorState.ValidationError => "Validation required",
            StudioContentEditorState.NotAuthorized => "Not authorized",
            _ => "Unavailable"
        };

    private static string FormatWorkflowState(StudioWorkflowActionState state) =>
        state switch
        {
            StudioWorkflowActionState.Loading => "Loading",
            StudioWorkflowActionState.Ready => "Ready",
            StudioWorkflowActionState.Processing => "Processing",
            StudioWorkflowActionState.Succeeded => "Completed",
            StudioWorkflowActionState.ValidationError => "Validation required",
            StudioWorkflowActionState.NotAuthorized => "Not authorized",
            _ => "Unavailable"
        };

    private static string FormatWorkflowReadiness(StudioContentLifecycleState state) =>
        state switch
        {
            StudioContentLifecycleState.Draft => "Draft can be submitted for review.",
            StudioContentLifecycleState.InReview => "Approve or return to draft.",
            StudioContentLifecycleState.Approved => "Approved content has no review actions here.",
            StudioContentLifecycleState.Published => "Published content has no review actions here.",
            StudioContentLifecycleState.Archived => "Archived content has no review actions here.",
            _ => "No review actions are available."
        };

    private static string GetStatusClass(StudioContentLifecycleState state) =>
        $"studio-content__status studio-content__status--{state.ToString().ToLowerInvariant()}";

    private async Task SaveDraftAsync()
    {
        var validation = Editor.Validate();
        if (!validation.Succeeded)
        {
            Editor.ApplyValidationResult(validation);
            return;
        }

        Editor.MarkSaving();

        var result = Editor.ContentId is null
            ? await StudioContentClient.CreateDraftAsync(Editor.ToCreateRequest(), CancellationToken.None)
            : await StudioContentClient.UpdateDraftAsync(Editor.ToUpdateRequest(), CancellationToken.None);

        ApplyEditorResult(result);
    }

    private void ApplyEditorResult(StudioContentClientResult<StudioContentEditorModel> result)
    {
        switch (result.Status)
        {
            case StudioContentClientStatus.Success when result.Value is not null:
                Editor = result.Value;
                Editor.MarkSaved();
                ApplySavedEditorToModel();
                break;
            case StudioContentClientStatus.ValidationError when result.Value is not null:
                Editor = result.Value;
                break;
            case StudioContentClientStatus.Unauthorized:
            case StudioContentClientStatus.Forbidden:
                Editor.MarkNotAuthorized(result.SafeMessage);
                break;
            default:
                Editor.MarkError(result.SafeMessage);
                break;
        }
    }

    private void ApplySavedEditorToModel()
    {
        if (Editor.ContentId is not { } contentId ||
            Editor.ContentType is not { } contentType ||
            Model.State != StudioContentPageState.Loaded)
        {
            return;
        }

        var existing = Model.Items.FirstOrDefault(item => item.Id == contentId);
        var savedAtUtc = DateTimeOffset.UtcNow;
        var savedItem = new StudioContentListItem(
            contentId,
            Editor.ApplicationId,
            Editor.ContentKey.Trim(),
            Editor.Title.Trim(),
            contentType,
            StudioContentLifecycleState.Draft,
            [
                new StudioContentVersionSummary(
                    existing?.CurrentVersion?.Id ?? Guid.NewGuid(),
                    Editor.Version,
                    StudioContentLifecycleState.Draft,
                    existing?.CurrentVersion?.CreatedAtUtc ?? savedAtUtc)
            ],
            new StudioContentHistorySummary(
                existing?.History.LifecycleEventCount ?? 1,
                existing?.History.PublishingEventCount ?? 0,
                "Draft metadata saved locally",
                savedAtUtc));

        var items = existing is null
            ? Model.Items.Concat([savedItem]).ToArray()
            : Model.Items.Select(item => item.Id == contentId ? savedItem : item).ToArray();

        Model = Model with
        {
            Items = items,
            SelectedContentId = contentId,
            SafeMessage = StudioContentFoundationData.LocalDataNotice
        };
        Workflow = StudioWorkflowActionModel.FromContent(Model.SelectedContent);
    }

    private bool HasIssue(string path) =>
        Editor.Issues.Any(issue => string.Equals(issue.Path, path, StringComparison.Ordinal));

    private bool IsWorkflowActionAvailable(StudioWorkflowActionKind action) =>
        StudioWorkflowActionModel.IsActionAvailable(Workflow.LifecycleState, action);

    private async Task RunWorkflowActionAsync(StudioWorkflowActionKind action)
    {
        var validation = Workflow.Validate(action);
        if (!validation.Succeeded)
        {
            Workflow.ApplyValidationResult(validation);
            return;
        }

        Workflow.MarkProcessing(action);
        var request = new StudioWorkflowActionRequest(Workflow.ContentId, Workflow.VersionId);
        var result = action switch
        {
            StudioWorkflowActionKind.RequestReview => await StudioContentClient.RequestReviewAsync(
                request,
                CancellationToken.None),
            StudioWorkflowActionKind.Approve => await StudioContentClient.ApproveAsync(
                request,
                CancellationToken.None),
            StudioWorkflowActionKind.Reject => await StudioContentClient.RejectAsync(
                request,
                CancellationToken.None),
            _ => StudioContentClientResult<StudioWorkflowActionModel>.InvalidResponse()
        };

        ApplyWorkflowResult(result);
    }

    private void ApplyWorkflowResult(StudioContentClientResult<StudioWorkflowActionModel> result)
    {
        switch (result.Status)
        {
            case StudioContentClientStatus.Success when result.Value is not null:
                Workflow = result.Value;
                ApplyWorkflowToModel();
                break;
            case StudioContentClientStatus.ValidationError when result.Value is not null:
                Workflow = result.Value;
                break;
            case StudioContentClientStatus.Unauthorized:
            case StudioContentClientStatus.Forbidden:
                Workflow.MarkNotAuthorized(result.SafeMessage);
                break;
            default:
                Workflow.MarkError(result.SafeMessage);
                break;
        }
    }

    private void ApplyWorkflowToModel()
    {
        if (Workflow.ContentId == Guid.Empty ||
            Workflow.VersionId == Guid.Empty ||
            Model.State != StudioContentPageState.Loaded)
        {
            return;
        }

        var existing = Model.Items.FirstOrDefault(item => item.Id == Workflow.ContentId);
        if (existing is null)
        {
            return;
        }

        var occurredAtUtc = DateTimeOffset.UtcNow;
        var versions = existing.Versions
            .Select(version => version.Id == Workflow.VersionId
                ? version with
                {
                    LifecycleState = Workflow.LifecycleState
                }
                : version)
            .ToArray();

        var updatedItem = existing with
        {
            LifecycleState = Workflow.LifecycleState,
            Versions = versions,
            History = existing.History with
            {
                LifecycleEventCount = existing.History.LifecycleEventCount + 1,
                LatestSafeActivity = Workflow.SafeMessage,
                LatestActivityAtUtc = occurredAtUtc
            }
        };

        Model = Model with
        {
            Items = Model.Items
                .Select(item => item.Id == updatedItem.Id ? updatedItem : item)
                .ToArray(),
            SelectedContentId = updatedItem.Id,
            SafeMessage = StudioContentFoundationData.LocalDataNotice
        };

        Editor = StudioContentEditorModel.FromContent(Model.SelectedContent);
    }

    private static StudioContentPageModel ToPageModel(
        StudioContentClientResult<StudioContentPageModel> result) =>
        result.Status switch
        {
            StudioContentClientStatus.Success when result.Value is not null => result.Value,
            StudioContentClientStatus.Unauthorized => StudioContentFoundationData.NotAuthorized() with
            {
                SafeMessage = result.SafeMessage
            },
            StudioContentClientStatus.Forbidden => StudioContentFoundationData.NotAuthorized() with
            {
                SafeMessage = result.SafeMessage
            },
            StudioContentClientStatus.NotFound => StudioContentFoundationData.Empty() with
            {
                SafeMessage = result.SafeMessage
            },
            _ => StudioContentFoundationData.Error() with
            {
                SafeMessage = result.SafeMessage
            }
        };
}
